// client/src/pages/lis-debug.tsx
// ============================================================================
// Liquidity Truth Console (LIS Debug Page)
// -----------------------------------------------------------------------------
// Canonical data source:
//   - Binance  → /lis
//   - Coinbase → /lis/coinbase
//
// TSLE v1.1 remains untouched.
// This page must NEVER carry over stale venue data after selection changes.
// ============================================================================

import React, { useEffect, useMemo, useRef, useState } from "react";
import type { Venue, LISResponse } from "../services/lis";
import { fetchLiquiditySnapshot } from "../services/lis";

type Token = "BTC";

function normalizeVenue(v: string): Venue {
  const x = (v || "").toLowerCase().trim();
  if (x === "binance") return "binance";
  if (x === "coinbase") return "coinbase";
  return "binance";
}

function formatUsd(n: number | undefined | null) {
  if (n === undefined || n === null || Number.isNaN(n)) return "—";
  const abs = Math.abs(n);
  if (abs >= 1e9) return `$${(n / 1e9).toFixed(2)}B`;
  if (abs >= 1e6) return `$${(n / 1e6).toFixed(2)}M`;
  if (abs >= 1e3) return `$${(n / 1e3).toFixed(2)}K`;
  return `$${n.toFixed(0)}`;
}

function formatPct(n: number | undefined | null, dp = 2) {
  if (n === undefined || n === null || Number.isNaN(n)) return "—";
  return `${n.toFixed(dp)}%`;
}

function getBand(data: LISResponse | null, key: string) {
  return data?.lis?.bands?.[key];
}

export default function LisDebugPage() {
  const [token, setToken] = useState<Token>("BTC");
  const [venue, setVenue] = useState<Venue>("binance");

  const [data, setData] = useState<LISResponse | null>(null);
  const [rawJsonOpen, setRawJsonOpen] = useState(false);

  const [loading, setLoading] = useState(false);
  const [error, setError] = useState<string | null>(null);
  const [lastUpdatedTs, setLastUpdatedTs] = useState<number | null>(null);

  const pollRef = useRef<number | null>(null);

  const titleVenue = useMemo(() => venue.toUpperCase(), [venue]);

  async function loadOnce(nextToken: Token, nextVenue: Venue) {
    setLoading(true);
    setError(null);

    try {
      const res = await fetchLiquiditySnapshot(nextToken, nextVenue);

      if (!res?.lis?.venue || normalizeVenue(res.lis.venue) !== nextVenue) {
        throw new Error(
          `Venue mismatch: requested=${nextVenue}, received=${res?.lis?.venue ?? "unknown"}`
        );
      }

      const bands = res?.lis?.bands;

      // ✅ FINAL FIX: soft error instead of throw
      if (!bands || Object.keys(bands).length === 0) {
        setData(null);
        setLastUpdatedTs(null);
        setError(`Depth not available for ${nextToken} on ${nextVenue}`);
        return;
      }

      setData(res);
      setLastUpdatedTs(Date.now());
    } catch (e: any) {
      setData(null);
      setLastUpdatedTs(null);
      setError(e?.message || `Failed to load LIS for ${nextToken} on ${nextVenue}`);
    } finally {
      setLoading(false);
    }
  }

  function stopPolling() {
    if (pollRef.current) {
      window.clearInterval(pollRef.current);
      pollRef.current = null;
    }
  }

  function startPolling(nextToken: Token, nextVenue: Venue) {
    stopPolling();
    void loadOnce(nextToken, nextVenue);
    pollRef.current = window.setInterval(() => {
      void loadOnce(nextToken, nextVenue);
    }, 5000);
  }

  useEffect(() => {
    setData(null);
    setError(null);
    setLastUpdatedTs(null);

    startPolling(token, venue);

    return () => stopPolling();
    // eslint-disable-next-line react-hooks/exhaustive-deps
  }, [token, venue]);

  const lis = data?.lis;
  const tsle = data?.tsle;

  const band10 = getBand(data, "pct_0.1");
  const band25 = getBand(data, "pct_0.25");
  const band50 = getBand(data, "pct_0.5");
  const band100 = getBand(data, "pct_1");
  const band200 = getBand(data, "pct_2");

  function imbalancePct(band: any) {
    if (!band) return null;
    const bid = Number(band.bid_notional ?? 0);
    const ask = Number(band.ask_notional ?? 0);
    const tot = bid + ask;
    if (!tot) return 0;
    return ((bid - ask) / tot) * 100;
  }

  const depthBadge = useMemo(() => {
    const p = tsle?.poli;
    if (p === undefined || p === null) return { label: "—", tone: "bg-zinc-700" };
    if (p >= 90) return { label: "STRONG", tone: "bg-emerald-600/20 text-emerald-300 border-emerald-600/40" };
    if (p >= 75) return { label: "FAIR", tone: "bg-amber-600/20 text-amber-300 border-amber-600/40" };
    return { label: "WEAK", tone: "bg-red-600/20 text-red-300 border-red-600/40" };
  }, [tsle?.poli]);

  return (
    <div className="min-h-screen bg-black text-zinc-100">
      <div className="mx-auto max-w-6xl px-6 py-8">
        {/* HEADER */}
        <div className="mb-6 flex items-start justify-between">
          <div>
            <h1 className="text-2xl font-semibold">Liquidity Truth Console</h1>
            <div className="text-sm text-zinc-400">
              LIS – Liquidity Ingestion Service – Ground Truth View
            </div>
            <div className="mt-2 italic text-zinc-400">
              “Price tells you where the market traded — liquidity quality tells you whether you could trade.”
            </div>
          </div>

          <div className="text-right text-sm text-zinc-400">
            {lastUpdatedTs ? (
              <div>Updated {new Date(lastUpdatedTs).toLocaleTimeString()}</div>
            ) : (
              <div>Updated —</div>
            )}
          </div>
        </div>

        {/* CONTROLS */}
        <div className="rounded-2xl border border-zinc-800 bg-zinc-950 p-5">
          <div className="flex flex-wrap items-center gap-4">
            <div className="flex items-center gap-3">
              <div className="text-xs text-zinc-400">TOKEN</div>
              <select
                className="rounded-xl border border-zinc-800 bg-black px-3 py-2 text-sm"
                value={token}
                onChange={(e) => setToken(e.target.value as Token)}
              >
                <option value="BTC">BTC</option>
              </select>
            </div>

            <div className="flex items-center gap-3">
              <div className="text-xs text-zinc-400">VENUE</div>
              <select
                className="rounded-xl border border-zinc-800 bg-black px-3 py-2 text-sm"
                value={venue}
                onChange={(e) => setVenue(normalizeVenue(e.target.value))}
              >
                <option value="binance">BINANCE</option>
                <option value="coinbase">COINBASE</option>
              </select>
            </div>

            <div className="ml-auto">
              <button
                className="rounded-xl border border-zinc-800 bg-black px-4 py-2 text-sm hover:bg-zinc-900"
                onClick={() => setRawJsonOpen((v) => !v)}
                disabled={!data}
              >
                Show Raw JSON
              </button>
            </div>
          </div>

          <div className="mt-4">
            {loading && (
              <div className="rounded-xl border border-zinc-800 bg-zinc-900/30 px-4 py-3 text-sm text-zinc-300">
                Loading {token} on {titleVenue}…
              </div>
            )}

            {!loading && error && (
              <div className="rounded-xl border border-red-900/60 bg-red-950/30 px-4 py-3 text-sm text-red-300">
                Error: {error}
              </div>
            )}
          </div>

          {rawJsonOpen && data && (
            <div className="mt-4 rounded-xl border border-zinc-800 bg-black p-4">
              <pre className="max-h-96 overflow-auto text-xs text-zinc-300">
                {JSON.stringify(data, null, 2)}
              </pre>
            </div>
          )}
        </div>

        {/* FOOTER */}
        <div className="mt-8 text-xs text-zinc-600">
          LIS v1.1 → TSLE v1.1 pipeline. Venue selection must always clear stale state before repainting.
        </div>
      </div>
    </div>
  );
}