/**
 * Coinbase Depth Ingress
 * ---------------------
 * Fetches L2 orderbook from Coinbase Exchange
 * Normalized to LIS depth-band format (10 / 25 / 50 / 100 / 200 bps)
 */

const https = require("https");

const COINBASE_API = "api.exchange.coinbase.com";

// Coinbase product mapping
const SYMBOL_MAP = {
  BTC: "BTC-USD",
  ETH: "ETH-USD",
  SOL: "SOL-USD",
  LTC: "LTC-USD",
  LINK: "LINK-USD",
  AVAX: "AVAX-USD"
};

// Depth bands (bps expressed as pct)
const BAND_DEFS = {
  pct_0_1: 0.001,   // 10 bps
  pct_0_25: 0.0025, // 25 bps
  pct_0_5: 0.005,   // 50 bps
  pct_1: 0.01,      // 100 bps
  pct_2: 0.02       // 200 bps
};

function httpGet(path) {
  return new Promise((resolve, reject) => {
    const req = https.get(
      {
        hostname: COINBASE_API,
        path,
        method: "GET",
        headers: {
          "User-Agent": "LIS-Ingress/1.0"
        }
      },
      res => {
        let data = "";
        res.on("data", d => (data += d));
        res.on("end", () => {
          try {
            resolve(JSON.parse(data));
          } catch (err) {
            reject(new Error("Invalid JSON from Coinbase"));
          }
        });
      }
    );

    req.on("error", reject);
  });
}

async function fetchOrderbook(symbol) {
  const productId = SYMBOL_MAP[symbol.toUpperCase()];
  if (!productId) {
    throw new Error(`Unsupported Coinbase symbol: ${symbol}`);
  }

  const data = await httpGet(`/products/${productId}/book?level=2`);

  if (!data.bids || !data.asks) {
    throw new Error("Invalid Coinbase orderbook response");
  }

  return {
    bids: data.bids.map(([p, q]) => [Number(p), Number(q)]),
    asks: data.asks.map(([p, q]) => [Number(p), Number(q)])
  };
}

function sumBidNotional(levels, minPrice) {
  let total = 0;
  for (const [price, qty] of levels) {
    if (price < minPrice) break;
    total += price * qty;
  }
  return total;
}

function sumAskNotional(levels, maxPrice) {
  let total = 0;
  for (const [price, qty] of levels) {
    if (price > maxPrice) break;
    total += price * qty;
  }
  return total;
}

async function getDepth(symbol) {
  const orderbook = await fetchOrderbook(symbol);

  if (!orderbook.bids.length || !orderbook.asks.length) {
    throw new Error("Empty orderbook");
  }

  const bestBid = orderbook.bids[0][0];
  const bestAsk = orderbook.asks[0][0];
  const mid = (bestBid + bestAsk) / 2;

  const spreadAbs = bestAsk - bestBid;
  const spreadBps = (spreadAbs / mid) * 10_000;

  const bands = {};
  let totalBidAll = 0;
  let totalAskAll = 0;

  for (const [bandKey, pct] of Object.entries(BAND_DEFS)) {
    const bidLimit = mid * (1 - pct);
    const askLimit = mid * (1 + pct);

    const bidNotional = sumBidNotional(orderbook.bids, bidLimit);
    const askNotional = sumAskNotional(orderbook.asks, askLimit);
    const total = bidNotional + askNotional;

    totalBidAll += bidNotional;
    totalAskAll += askNotional;

    bands[bandKey] = {
      bid_notional: Number(bidNotional.toFixed(2)),
      ask_notional: Number(askNotional.toFixed(2)),
      total_notional: Number(total.toFixed(2))
    };
  }

  const denom = totalBidAll + totalAskAll;

  return {
    venue: "coinbase",
    symbol: symbol.toUpperCase(),
    quote: "USD",
    timestamp: Date.now(),
    mid_price: Number(mid.toFixed(8)),
    spread: {
      absolute: Number(spreadAbs.toFixed(8)),
      bps: Number(spreadBps.toFixed(4))
    },
    bands,
    metrics: {
      bid_ask_balance: denom === 0 ? 0 : totalBidAll / denom,
      depth_asymmetry:
        denom === 0 ? 0 : Math.abs(totalBidAll - totalAskAll) / denom,
      source: "lis-v1"
    }
  };
}

module.exports = {
  getDepth,
  SYMBOL_MAP
};